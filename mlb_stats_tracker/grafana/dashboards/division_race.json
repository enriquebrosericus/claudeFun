{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ],
  "title": "MLB — Division Race",
  "uid": "mlb-division-race",
  "tags": ["mlb", "baseball", "standings"],
  "refresh": "5m",
  "time": {"from": "now-1y", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRES",
        "type": "datasource",
        "query": "postgres",
        "hide": 2
      },
      {
        "name": "season",
        "label": "Season",
        "type": "custom",
        "query": "2025,2026",
        "hide": 0,
        "current": {"selected": true, "text": "2025", "value": "2025"},
        "options": [
          {"selected": true, "text": "2025", "value": "2025"},
          {"selected": false, "text": "2026", "value": "2026"}
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "▓▒░ AMERICAN LEAGUE ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "table",
      "title": "AL East — Standings",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Team"},
            "properties": [
              {"id": "custom.width", "value": 60},
              {"id": "custom.align", "value": "left"},
              {"id": "color", "value": {"fixedColor": "#00FFFF", "mode": "fixed"}},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "W"},
            "properties": [
              {"id": "decimals", "value": 0},
              {"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "L"},
            "properties": [
              {"id": "decimals", "value": 0},
              {"id": "color", "value": {"fixedColor": "#FF00FF", "mode": "fixed"}},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "PCT"},
            "properties": [{"id": "decimals", "value": 3}]
          },
          {
            "matcher": {"id": "byName", "options": "GB"},
            "properties": [
              {"id": "decimals", "value": 1},
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#00FFFF", "value": null},
                    {"color": "#FF9500", "value": 3},
                    {"color": "#FF1493", "value": 8}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {"show": false},
        "sortBy": [{"displayName": "GB", "desc": false}]
      },
      "targets": [
        {
          "rawSql": "SELECT team AS \"Team\", wins AS \"W\", losses AS \"L\", CASE WHEN wins+losses > 0 THEN ROUND(wins::numeric/(wins+losses),3) ELSE 0 END AS \"PCT\", games_behind AS \"GB\" FROM division_standings WHERE division='AL East' AND season=${season} AND game_type='R' AND date = (SELECT MAX(date) FROM division_standings WHERE division='AL East' AND season=${season} AND game_type='R') ORDER BY games_behind, wins DESC",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
