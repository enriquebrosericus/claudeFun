    {
      "id": 5,
      "type": "timeseries",
      "title": "AL East — Division Race",
      "gridPos": {"h": 10, "w": 8, "x": 0, "y": 8},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 3,
            "fillOpacity": 10,
            "spanNulls": true,
            "axisLabel": "Games Ahead (0 = 1st place)",
            "gradientMode": "opacity"
          },
          "unit": "none",
          "decimals": 1
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "TOR"},
            "properties": [{"id": "color", "value": {"fixedColor": "#00FFFF", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "NYY"},
            "properties": [{"id": "color", "value": {"fixedColor": "#BF00FF", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "BOS"},
            "properties": [{"id": "color", "value": {"fixedColor": "#FF1493", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "TB"},
            "properties": [{"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "BAL"},
            "properties": [{"id": "color", "value": {"fixedColor": "#FF6B00", "mode": "fixed"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "calcs": ["last"], "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "asc"}
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", MAX(CASE WHEN team='TOR' THEN -games_behind END) AS \"TOR\", MAX(CASE WHEN team='NYY' THEN -games_behind END) AS \"NYY\", MAX(CASE WHEN team='BOS' THEN -games_behind END) AS \"BOS\", MAX(CASE WHEN team='TB' THEN -games_behind END) AS \"TB\", MAX(CASE WHEN team='BAL' THEN -games_behind END) AS \"BAL\" FROM division_standings WHERE division='AL East' AND season=${season} AND game_type='R' AND $__timeFilter(date) GROUP BY date ORDER BY date",
          "format": "time_series",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
