{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ],
  "title": "MLB — Teams",
  "uid": "mlb-sea-team",
  "tags": ["mlb", "baseball"],
  "refresh": "5m",
  "time": {"from": "now-1y", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRES",
        "type": "datasource",
        "query": "postgres",
        "hide": 2
      },
      {
        "name": "season",
        "label": "Season",
        "type": "custom",
        "query": "2025,2026",
        "hide": 0,
        "current": {"selected": true, "text": "2025", "value": "2025"},
        "options": [
          {"selected": true, "text": "2025", "value": "2025"},
          {"selected": false, "text": "2026", "value": "2026"}
        ]
      },
      {
        "name": "game_type",
        "label": "Game Type",
        "type": "custom",
        "query": "Regular Season : R, Spring Training : S",
        "hide": 0,
        "current": {"selected": true, "text": "Regular Season", "value": "R"},
        "options": [
          {"selected": true, "text": "Regular Season", "value": "R"},
          {"selected": false, "text": "Spring Training", "value": "S"}
        ]
      },
      {
        "name": "team",
        "label": "Team",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
        "query": "SELECT DISTINCT team FROM division_standings WHERE season=${season} AND game_type='R' ORDER BY team",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 1,
        "current": {"selected": true, "text": "SEA", "value": "SEA"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "▓▒░ SEASON RECORD ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "WINS",
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"fixedColor": "#39FF14", "mode": "fixed"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "#39FF14", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT wins FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "LOSSES",
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"fixedColor": "#FF00FF", "mode": "fixed"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "#FF00FF", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT losses FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "WIN %",
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF1493", "value": null},
              {"color": "#FF9500", "value": 0.45},
              {"color": "#00FFFF", "value": 0.55}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT win_pct FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GAMES BACK",
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#00FFFF", "value": null},
              {"color": "#FF9500", "value": 3},
              {"color": "#FF1493", "value": 8}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT games_behind FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "STREAK",
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF1493", "value": null},
              {"color": "#FF9500", "value": 0},
              {"color": "#00FFFF", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"},
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/.*/"},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT streak FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "LAST 10",
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF1493", "value": null},
              {"color": "#FF9500", "value": 5},
              {"color": "#00FFFF", "value": 7}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "rawSql": "SELECT last10_wins FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "▓▒░ SEASON TRENDS ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Wins & Losses Over Season",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 3,
            "fillOpacity": 20,
            "lineInterpolation": "stepAfter",
            "gradientMode": "opacity"
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "wins"},
            "properties": [{"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "losses"},
            "properties": [{"id": "color", "value": {"fixedColor": "#FF00FF", "mode": "fixed"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "calcs": ["last"], "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", wins, losses FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' AND $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Run Differential",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 3,
            "fillOpacity": 30,
            "lineInterpolation": "stepAfter",
            "gradientMode": "scheme"
          },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF00FF", "value": null},
              {"color": "#00FFFF", "value": 0}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", (runs_scored - runs_allowed) AS \"Run Differential\" FROM team_stats WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' AND $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "▓▒░ DIVISION STANDING ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}
    },
    {
      "id": 14,
      "type": "table",
      "title": "Division — Current Standings",
      "gridPos": {"h": 8, "w": 10, "x": 0, "y": 19},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "cellOptions": {"type": "color-text"}
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Team"},
            "properties": [
              {"id": "custom.width", "value": 60},
              {"id": "custom.align", "value": "left"},
              {"id": "color", "value": {"fixedColor": "#00FFFF", "mode": "fixed"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "W"},
            "properties": [
              {"id": "decimals", "value": 0},
              {"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "L"},
            "properties": [
              {"id": "decimals", "value": 0},
              {"id": "color", "value": {"fixedColor": "#FF00FF", "mode": "fixed"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "PCT"},
            "properties": [
              {"id": "decimals", "value": 3},
              {"id": "color", "value": {"fixedColor": "#BF00FF", "mode": "fixed"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "GB"},
            "properties": [
              {"id": "decimals", "value": 1},
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#00FFFF", "value": null},
                    {"color": "#FF9500", "value": 3},
                    {"color": "#FF1493", "value": 8}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {"show": false},
        "sortBy": [{"displayName": "GB", "desc": false}],
        "frameIndex": 0,
        "showHeader": true
      },
      "targets": [
        {
          "rawSql": "SELECT team AS \"Team\", wins AS \"W\", losses AS \"L\", CASE WHEN wins+losses > 0 THEN ROUND(wins::numeric/(wins+losses),3) ELSE 0 END AS \"PCT\", games_behind AS \"GB\" FROM division_standings WHERE season=${season} AND game_type='R' AND division = (SELECT division FROM division_standings WHERE team='${team}' AND season=${season} AND game_type='R' ORDER BY date DESC LIMIT 1) AND date = (SELECT MAX(date) FROM division_standings WHERE season=${season} AND game_type='R') ORDER BY games_behind",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Division Race — Games Ahead",
      "gridPos": {"h": 8, "w": 14, "x": 10, "y": 19},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 3,
            "fillOpacity": 15,
            "spanNulls": true,
            "axisLabel": "Games Ahead of 1st Place (0 = tied for 1st)",
            "gradientMode": "opacity"
          },
          "unit": "none",
          "decimals": 1,
          "color": {"fixedColor": "#00F0FF", "mode": "fixed"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "asc"}
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"time\", -games_behind AS \"Games Ahead\" FROM division_standings WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}' AND $__timeFilter(date) ORDER BY date",
          "format": "time_series",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "▓▒░ BATTING LEADERBOARD ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28}
    },
    {
      "id": 21,
      "type": "table",
      "title": "Batters — Season Stats",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 29},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {"unit": "none", "decimals": 3},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Player"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "#00FFFF", "mode": "fixed"}},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {"matcher": {"id": "byName", "options": "HR"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#FF6B00", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "RBI"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#00F0FF", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "R"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "H"}, "properties": [{"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "SB"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#BF00FF", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "G"}, "properties": [{"id": "decimals", "value": 0}]},
          {
            "matcher": {"id": "byName", "options": "OPS"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#FF1493", "value": null},
                    {"color": "#FF9500", "value": 0.7},
                    {"color": "#00FFFF", "value": 0.8},
                    {"color": "#39FF14", "value": 0.9}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{"displayName": "OPS", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [
        {
          "rawSql": "SELECT player AS \"Player\", avg AS \"AVG\", obp AS \"OBP\", slg AS \"SLG\", ops AS \"OPS\", home_runs AS \"HR\", rbi AS \"RBI\", runs AS \"R\", hits AS \"H\", stolen_bases AS \"SB\", games_played AS \"G\" FROM player_batting WHERE team = '${team}' AND season = ${season} AND date = (SELECT MAX(date) FROM player_batting WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}') AND at_bats > 0 ORDER BY ops DESC NULLS LAST",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "▓▒░ PITCHING LEADERBOARD ░▒▓",
      "collapsed": false,
      "panels": [],
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 42}
    },
    {
      "id": 31,
      "type": "table",
      "title": "Pitchers — Season Stats",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 43},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {"unit": "none", "decimals": 2},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Player"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "#00FFFF", "mode": "fixed"}},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {"matcher": {"id": "byName", "options": "W"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "L"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#FF00FF", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "SV"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#00F0FF", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "SO"}, "properties": [
            {"id": "decimals", "value": 0},
            {"id": "color", "value": {"fixedColor": "#BF00FF", "mode": "fixed"}},
            {"id": "custom.cellOptions", "value": {"type": "color-text"}}
          ]},
          {"matcher": {"id": "byName", "options": "G"}, "properties": [{"id": "decimals", "value": 0}]},
          {
            "matcher": {"id": "byName", "options": "ERA"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#00FFFF", "value": null},
                    {"color": "#FF9500", "value": 3.5},
                    {"color": "#FF1493", "value": 5.0}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "WHIP"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "#00FFFF", "value": null},
                    {"color": "#FF9500", "value": 1.2},
                    {"color": "#FF1493", "value": 1.5}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{"displayName": "ERA", "desc": false}],
        "footer": {"show": false}
      },
      "targets": [
        {
          "rawSql": "SELECT player AS \"Player\", games AS \"G\", wins AS \"W\", losses AS \"L\", saves AS \"SV\", innings_pitched AS \"IP\", strikeouts AS \"SO\", era AS \"ERA\", whip AS \"WHIP\", k9 AS \"K/9\", fip AS \"FIP\" FROM player_pitching WHERE team = '${team}' AND season = ${season} AND date = (SELECT MAX(date) FROM player_pitching WHERE team = '${team}' AND season = ${season} AND game_type = '${game_type}') AND innings_pitched > 0 ORDER BY era ASC NULLS LAST",
          "format": "table",
          "refId": "A",
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
        }
      ]
    }
  ]
}
