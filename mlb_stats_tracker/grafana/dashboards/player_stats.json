{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ],
  "title": "Mariners — Player Detail",
  "uid": "mlb-sea-player",
  "tags": ["mlb", "mariners", "baseball", "player"],
  "refresh": "5m",
  "time": {"from": "now-1y", "to": "now"},
  "timezone": "browser",
  "schemaVersion": 38,
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "DS_POSTGRES",
        "type": "datasource",
        "query": "postgres",
        "hide": 2
      },
      {
        "name": "season",
        "label": "Season",
        "type": "custom",
        "query": "2025,2026",
        "hide": 0,
        "current": {"selected": true, "text": "2025", "value": "2025"},
        "options": [
          {"selected": true, "text": "2025", "value": "2025"},
          {"selected": false, "text": "2026", "value": "2026"}
        ]
      },
      {
        "name": "game_type",
        "label": "Game Type",
        "type": "custom",
        "query": "Regular Season : R, Spring Training : S",
        "hide": 0,
        "current": {"selected": true, "text": "Regular Season", "value": "R"},
        "options": [
          {"selected": true, "text": "Regular Season", "value": "R"},
          {"selected": false, "text": "Spring Training", "value": "S"}
        ]
      },
      {
        "name": "batter",
        "label": "Batter",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
        "query": "SELECT DISTINCT player FROM player_batting WHERE team = 'SEA' AND season = ${season} AND game_type = '${game_type}' ORDER BY player",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 1,
        "current": {}
      },
      {
        "name": "pitcher",
        "label": "Pitcher",
        "type": "query",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
        "query": "SELECT DISTINCT player FROM player_pitching WHERE team = 'SEA' AND season = ${season} AND game_type = '${game_type}' ORDER BY player",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "row",
      "title": "▓▒░ BATTER — ${batter} ░▒▓",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "stat", "title": "AVG",
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "#FF1493", "value": null},
              {"color": "#FF9500", "value": 0.250},
              {"color": "#00FFFF", "value": 0.300}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{
        "rawSql": "SELECT avg FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
        "format": "table", "refId": "A",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
      }]
    },
    {
      "id": 3, "type": "stat", "title": "OBP",
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 1},
