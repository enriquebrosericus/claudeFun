              {"color": "#FF9500", "value": 0.320},
              {"color": "#00FFFF", "value": 0.370}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{
        "rawSql": "SELECT obp FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
        "format": "table", "refId": "A",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
      }]
    },
    {
      "id": 4, "type": "stat", "title": "SLG",
