        "rawSql": "SELECT slg FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
        "format": "table", "refId": "A",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
      }]
    },
    {
      "id": 5, "type": "stat", "title": "OPS",
      "gridPos": {"h": 4, "w": 3, "x": 9, "y": 1},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
