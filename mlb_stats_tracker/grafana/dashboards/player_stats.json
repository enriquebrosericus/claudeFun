        "defaults": {
          "unit": "none",
          "color": {"fixedColor": "#00F0FF", "mode": "fixed"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "#00F0FF", "value": null}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{
        "rawSql": "SELECT rbi FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
