    {
      "id": 10, "type": "timeseries", "title": "HR & RBI Progression",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line", "lineWidth": 3,
            "fillOpacity": 15, "lineInterpolation": "stepAfter",
            "gradientMode": "opacity"
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "home_runs"},
            "properties": [{"id": "color", "value": {"fixedColor": "#FF6B00", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "rbi"},
            "properties": [{"id": "color", "value": {"fixedColor": "#00F0FF", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "runs"},
            "properties": [{"id": "color", "value": {"fixedColor": "#39FF14", "mode": "fixed"}}]
          }
        ]
      },
      "options": {
        "legend": {"displayMode": "table", "calcs": ["last"], "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi"}
      },
      "targets": [{
        "rawSql": "SELECT date AS \"time\", home_runs, rbi, runs FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' AND $__timeFilter(date) ORDER BY date",
        "format": "time_series", "refId": "A",
        "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"}
      }]
