      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{
        "rawSql": "SELECT ops FROM player_batting WHERE player = '${batter}' AND season = ${season} AND game_type = '${game_type}' ORDER BY date DESC LIMIT 1",
